{
  "name": "opencode-x402",
  "version": "0.1.0",
  "description": "x402 wallet plugin for opencode — auto-pay for LLM inference per request with USDC on Base. Ships with a Surplus Intelligence provider preset.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "opencode-x402": "./src/cli.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "x402",
    "usdc",
    "base",
    "micropayments"
  ],
  "license": "MIT",
  "author": "Lem (https://github.com/lemkova)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lemkova/opencode-x402.git"
  },
  "bugs": {
    "url": "https://github.com/lemkova/opencode-x402/issues"
  },
  "homepage": "https://github.com/lemkova/opencode-x402#readme",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun run scripts/seed-test.ts",
    "smoke": "bun run scripts/smoke.ts"
  },
  "dependencies": {
    "@scure/bip39": "2.2.0",
    "@x402/core": "2.19.0",
    "@x402/evm": "2.19.0",
    "viem": "2.55.8"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/bun": "^1.3.0",
    "typescript": "^5.6.0"
  }
}
